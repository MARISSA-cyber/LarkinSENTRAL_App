<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/vintage_gold"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1.5dp" android:color="@color/vintage_brown"/>
        </shape>
    </item>
    <!-- Normal available state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/vintage_cream"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1.5dp" android:color="@color/vintage_brown_light"/>
        </shape>
    </item>
</selector>
