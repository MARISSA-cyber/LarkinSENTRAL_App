<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vintage_cream">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/vintage_brown"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LARKIN SENTRAL BUS TERMINAL"
            android:textColor="@color/vintage_gold"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:fontFamily="serif"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Confirmed"
            android:textColor="@color/vintage_cream"
            android:textSize="22sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Big checkmark -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/card_bg"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#10003;"
                    android:textColor="@color/vintage_green"
                    android:textSize="48sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your booking is confirmed!"
                android:textColor="@color/vintage_brown_dark"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please collect your ticket at the counter."
                android:textColor="@color/vintage_brown_light"
                android:textSize="12sp"
                android:fontFamily="serif"
                android:layout_marginBottom="20dp"/>

            <!-- Ticket stub card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg">

                <!-- Gold top strip -->
                <View android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="@color/vintage_gold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Ref number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BOOKING REF"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvConfirmRef"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LRK-20260317-00000"
                            android:textColor="@color/vintage_brown"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@drawable/divider_dashed" android:layout_marginBottom="12dp"/>

                    <!-- Passenger name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PASSENGER"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <!-- Route -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ROUTE"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JB Larkin  &#8594;  KL TBS"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <!-- Seats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SEAT(S)"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvConfirmSeats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <!-- Date + Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DATE / TIME"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="21 Mar 2026  ·  08:00 AM"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@drawable/divider_dashed" android:layout_marginBottom="12dp"/>

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL PAID"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvConfirmTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM 0.00"
                            android:textColor="@color/vintage_brown"
                            android:textSize="20sp"
                            android:fontFamily="serif"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Gold bottom strip -->
                <View android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="@color/vintage_gold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#10022;  Show this reference at counter or kiosk  &#10022;"
                android:textColor="@color/vintage_brown_light"
                android:textSize="11sp"
                android:fontFamily="serif"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_bar_bg"
        android:padding="16dp">

        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="BACK TO HOME"
            android:background="@drawable/btn_primary"
            android:textColor="@color/vintage_cream"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:onClick="backhome"/>
    </LinearLayout>

</LinearLayout>
