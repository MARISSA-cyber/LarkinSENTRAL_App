<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vintage_cream">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/vintage_red"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textColor="@color/vintage_gold"
            android:textSize="20sp"
            android:padding="4dp"
            android:fontFamily="serif"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:letterSpacing="0.3"
                android:text="@string/larkin_sentral1"
                android:textColor="#F9A825"
                android:textSize="9sp"
                tools:ignore="SmallSp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/booking_summary1"
                android:textColor="@color/vintage_cream"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── SCROLL ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── TICKET CARD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="0dp">

                <!-- Ticket top gold strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="@color/vintage_gold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Company branding -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/larkin_sentral_bus_terminal1"
                        android:textColor="@color/vintage_brown"
                        android:textSize="12sp"
                        android:letterSpacing="0.15"
                        android:fontFamily="serif"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/e_ticket_tiket_elektronik1"
                        android:textColor="@color/vintage_brown_light"
                        android:textSize="10sp"
                        android:fontFamily="serif"
                        android:layout_marginBottom="12dp"
                        tools:ignore="SmallSp" />

                    <!-- Dashed divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- FROM → TO row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        tools:ignore="DisableBaselineAlignment">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/from1"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Johor Bahru"
                                android:id="@+id/origin"
                                android:textColor="@color/vintage_brown_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/larkin_sentral2"
                                android:textColor="@color/vintage_brown_light"
                                android:textSize="11sp"
                                android:fontFamily="serif"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="────"
                                android:textColor="@color/vintage_gold"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textColor="@color/vintage_gold"
                                android:textSize="20sp"
                                android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/to1"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/destination"
                                android:text="Kuala Lumpur"
                                android:textColor="@color/vintage_brown_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tbs_terminal1"
                                android:textColor="@color/vintage_brown_light"
                                android:textSize="11sp"
                                android:fontFamily="serif"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Dashed divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- Details Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        tools:ignore="DisableBaselineAlignment">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/date"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:id="@+id/tvDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="21 March 2026"
                                style="@style/VintageValue"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/departs1"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:00 AM"
                                style="@style/VintageValue"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ARRIVES"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="~12:30 AM"
                                style="@style/VintageValue"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        tools:ignore="DisableBaselineAlignment">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BUS TYPE"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Express Coach"
                                style="@style/VintageValue"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/operator"
                                style="@style/VintageLabel"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Transnasional"
                                style="@style/VintageValue"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Dashed divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- Selected Seats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SEAT(S) SELECTED"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvSummarySeats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NO. OF PASSENGERS"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:id="@+id/tvPassengerCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            style="@style/VintageValue"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PRICE PER SEAT"
                            style="@style/VintageLabel"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM 35.00"
                            style="@style/VintageValue"/>
                    </LinearLayout>

                    <!-- Dashed divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL AMOUNT"
                            android:textColor="@color/vintage_brown"
                            android:textSize="13sp"
                            android:fontFamily="serif"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvSummaryTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM 0.00"
                            android:textColor="@color/vintage_brown"
                            android:textSize="22sp"
                            android:fontFamily="serif"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Ticket bottom gold strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="@color/vintage_gold"/>

            </LinearLayout>

            <!-- ── PASSENGER INFO CARD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSENGER INFORMATION"
                    android:textColor="@color/vintage_brown"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL NAME"
                    style="@style/VintageLabel"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/vintage_brown_light"
                    android:fontFamily="serif"
                    android:hint="e.g. Ahmad bin Abdullah"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="8dp"
                    android:textColor="@color/vintage_brown_dark"
                    android:textColorHint="@color/gray_light"
                    android:textSize="14sp" />

                <!-- IC / Passport -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IC / PASSPORT NO."
                    style="@style/VintageLabel"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etIc"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/vintage_brown_light"
                    android:fontFamily="serif"
                    android:hint="e.g. 900101-01-1234"
                    android:inputType="number"
                    android:paddingHorizontal="8dp"
                    android:textColor="@color/vintage_brown_dark"
                    android:textColorHint="@color/gray_light"
                    android:textSize="14sp"
                    tools:ignore="Autofill,VisualLintTextFieldSize" />

                <!-- Phone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHONE NUMBER"
                    style="@style/VintageLabel"
                    android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="e.g. 012-3456789"
                    android:textSize="14sp"
                    android:fontFamily="serif"
                    android:backgroundTint="@color/vintage_brown_light"
                    android:textColorHint="@color/gray_light"
                    android:textColor="@color/vintage_brown_dark"
                    android:paddingHorizontal="8dp"
                    android:inputType="phone"/>
            </LinearLayout>

            <!-- Spacing at bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ── BOTTOM BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_bar_bg"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_handled_at_counter_terminal_kiosk"
            android:textColor="@color/vintage_brown_light"
            android:textSize="10sp"
            android:fontFamily="serif"
            android:layout_marginBottom="8dp"
            tools:ignore="SmallSp" />

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/vintage_red"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:stateListAnimator="@null"
            android:text="@string/confirm_booking1"
            android:textColor="@color/vintage_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:ignore="TextContrastCheck,VisualLintButtonSize"
            android:onClick="payment"/>
    </LinearLayout>
</LinearLayout>
