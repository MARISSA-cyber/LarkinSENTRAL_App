<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#E53935"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@null"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"/>

        <!-- Page Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Bus"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_centerInParent="true"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnSort"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="Sort"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFFFFF" />
        </LinearLayout>


    </RelativeLayout>

    <!-- Trip Summary -->
    <LinearLayout
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FCD299"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTripRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Johor Bahru → Kuala Lumpur"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvDepartDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Departure: 18/03/2026"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvReturnDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Return: 20/03/2026"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:textColor="#000000"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- RecyclerView for buses -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBuses"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>
</LinearLayout>